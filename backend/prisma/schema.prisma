generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  @@map("users")
}

model Campaign {
  id       String @id @default(uuid())
  nome     String
  custo    Float
  receita  Float
  taxas    Float? @default(0)
  despesas Float? @default(0)

  @@map("campaigns")
}
