generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  @@map("users")
}

model Campaign {
  id       String @id @default(uuid())
  name     String
  cost     Float
  revenue  Float
  tax      Float? @default(0)
  expense  Float? @default(0)

  @@map("campaigns")
}
